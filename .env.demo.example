# Copy this file to .env for the shortest command:
#   docker compose up --build
COMPOSE_FILE=docker-compose.demo.yml

APP_CORE_VERSION=0.7.0-alpha.1
EVM_CONTRACTS_VERSION=0.7.0-alpha.1
CONTROL_PLANE_VERSION=0.7.0-alpha.1
TYPES_VERSION=0.7.0-alpha.1
SDK_VERSION=0.7.0-alpha.1
DOCS_VERSION=0.7.0-alpha.1
THEME_DEFAULT_VERSION=0.6.0-alpha.3

POSTGRES_USER=isonia
POSTGRES_PASSWORD=isonia_local_demo_password
POSTGRES_DB=isonia_demo

API_PORT=3000
APP_PORT=5173
HARDHAT_RPC_URL=http://127.0.0.1:8545
CHAIN_ID=31337
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Leave empty to use app-core injected wallet fallback.
REOWN_PROJECT_ID=

createProposal=true
writeActions=true
manageOrg=true
