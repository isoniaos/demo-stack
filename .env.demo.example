# Copy this file to .env for the shortest command:
#   docker compose up --build
COMPOSE_FILE=docker-compose.demo.yml

APP_CORE_VERSION=0.8.0-alpha.1
EVM_CONTRACTS_VERSION=0.8.0-alpha.1
CONTROL_PLANE_VERSION=0.8.0-alpha.1
VALIDATE_V08_SEED=true
ISONIA_PROTOCOL_PROFILE=current
ISONIA_DEPLOYMENT_CAPABILITIES_JSON={"activation":{"contractBatch":true},"finalization":{"organization":true}}

POSTGRES_USER=isonia
POSTGRES_PASSWORD=isonia_local_demo_password
POSTGRES_DB=isonia_demo

API_PORT=3000
APP_PORT=5173
HARDHAT_RPC_URL=http://127.0.0.1:8545
CHAIN_ID=31337
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Leave empty to use app-core injected wallet fallback.
REOWN_PROJECT_ID=
WALLET_CONNECTION_MODE=injected-only
HARDHAT_VERBOSE_LOGS=false

createProposal=true
writeActions=true
manageOrg=true
